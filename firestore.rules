rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      
      match /usage/{date} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      }
    }
    match /referral_claims/{claimId} {
      allow read, write: if request.auth != null;
    }
    match /admins/{adminId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == adminId || exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
  }
}
