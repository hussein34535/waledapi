{
  "rules": {
    "vpsAccounts": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["type", "createdAt", "userId"],
      "$accountId": {
        ".validate": "newData.hasChildren(['type', 'server_name', 'status', 'createdAt', 'updatedAt'])",
        "type": {
          ".validate": "newData.val().length <= 10 && (newData.val() === 'SSH' || newData.val() === 'VMESS' || newData.val() === 'VLESS' || newData.val() === 'SLOWDNS')"
        },
        "server_name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200" },
        "ip_address": { ".validate": "newData.isString() && newData.val().length <= 45" },
        "username": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "password": { ".validate": "newData.isString() && newData.val().length <= 500" },
        "ssh_string": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "dns_ip": { ".validate": "newData.isString() && newData.val().length <= 45" },
        "ns": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "public_key": { ".validate": "newData.isString() && newData.val().length <= 500" },
        "port": { ".validate": "newData.isNumber() || (newData.isString() && newData.val().length <= 10)" },
        "expiry_date": { ".validate": "newData.isString() && newData.val().length <= 20" },
        "config": { ".validate": "newData.isString() && newData.val().length <= 2000" },
        "status": { ".validate": "newData.val() === 'active' || newData.val() === 'inactive'" },
        "userId": { ".validate": "newData.isString() && newData.val() === auth.uid" },
        "createdAt": { ".validate": "newData.isNumber() && newData.val() > 1700000000000 && newData.val() < 3000000000000" },
        "updatedAt": { ".validate": "newData.isNumber() && newData.val() > 1700000000000 && newData.val() < 3000000000000" },
        "$other": { ".validate": false }
      }
    },
    "sni": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["host"],
      "$name": {
        ".validate": "newData.hasChildren(['host'])",
        "host": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 253" },
        "createdBy": { ".validate": "newData.isString() && newData.val() === auth.uid" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "updatedBy": { ".validate": "newData.isString() && newData.val() === auth.uid" },
        "updatedAt": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },
    "config": {
      "pricing": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
